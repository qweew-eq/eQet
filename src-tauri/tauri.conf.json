{
    "$schema": "https://schema.tauri.app/config/v2",
  "productName": "eQet",
  "version": "0.1.0",
  "identifier": "void.eqet.eq",
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/16x16.png",
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENENDMzNzY5Njg1NDA3OUYKUldTZkIxUm9hVGREemJZRWNvSkFCRDJTYnlrKzUzOUY0U25vdGZyZXE3NkkyZlNLSnpuKzEwNWEK",
      "endpoints": [
        "https://eqet-eew.pages.dev/updates/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  },
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
